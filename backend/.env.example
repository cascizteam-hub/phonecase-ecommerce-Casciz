NODE_ENV=development
PORT=5001

# MongoDB Atlas connection string (production/real dev)
# e.g. mongodb+srv://<user>:<password>@cluster0.mongodb.net/phonecase
MONGO_URI=

# If MONGO_URI is left empty in development, the server falls back to an
# in-memory MongoDB instance automatically (data is not persisted).

JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Instagram Graph API (requires an Instagram Business/Creator account
# linked to a Facebook Page, and a Meta app with the Instagram Graph
# API product enabled). Used to power the homepage Instagram feed.
IG_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
